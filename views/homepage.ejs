<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FitLog</title>
  </head>

  <body>
    <h1>Welcome to FitLog</h1>

    <p>Create workout routines and track your exercises.</p>

    <% if (user) { %>
      <p>Welcome, <%= user.username %></p>

      <a href="/routines">My Routines</a>

      <br /><br />

      <a href="/routines/new">Create New Routine</a>

      <br /><br />

      <a href="/public-routines">View Public Routines</a>

      <br /><br />

      <a href="/auth/sign-out">Sign Out</a>
    <% } else { %>
      <a href="/auth/sign-up">Sign Up</a>

      <br /><br />

      <a href="/auth/sign-in">Sign In</a>

      <br /><br />

      <a href="/public-routines">View Public Routines</a>
    <% } %>
  </body>
</html>
