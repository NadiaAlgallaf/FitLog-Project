<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title><%= routine.workoutName %></title>
  </head>
  <body>
    <%- include('../partials/navbar.ejs') %>

  <main class="page-container">
      <div class="routine-header">
        <div>
          <p class="small-title">Workout Routine</p>

          <h1><%= routine.workoutName %></h1>

          <% if (routine.description) { %>
            <p class="routine-description">
              <%= routine.description %>
            </p>
          <% } %>

          <% if (routine.owner) { %>
            <p class="secondary-text">
              Created by: <%= routine.owner.username %>
            </p>
          <% } %>
        </div>

        <% if (routine.isPublic) { %>
          <span class="public-badge">Public</span>
        <% } else { %>
          <span class="private-badge">Private</span>
        <% } %>
      </div>

      <% if (isOwner) { %>
        <div class="page-actions">
          <a
            href="/routines/<%= routine._id %>/exercises/new"
            class="primary-button"
          >
            Add Exercise
          </a>
        </div>
      <% } %>

      <div class="section-heading">
        <h2>Exercises</h2>
      </div>

      <% if (workoutExercises.length === 0) { %>
        <div class="empty-card">
          <h2>No Exercises Yet</h2>

          <p>No exercises have been added to this routine.</p>

          <% if (isOwner) { %>
            <a
              href="/routines/<%= routine._id %>/exercises/new"
              class="primary-button"
            >
              Add First Exercise
            </a>
          <% } %>
        </div>
      <% } else { %>
        <div class="exercise-list">
          <% for (let workoutExercise of workoutExercises) { %>
            <div class="exercise-card">
              <% if (workoutExercise.exercise) { %>
                <div class="exercise-information">
                  <% if (workoutExercise.exercise.exerciseGif) { %>
                    <img
                      class="exercise-image"
                      src="<%= workoutExercise.exercise.exerciseGif %>"
                      alt="<%= workoutExercise.exercise.exerciseName %>"
                    />
                  <% } %>

                  <div class="exercise-details">
                    <h3>
                      <%= workoutExercise.exercise.exerciseName %>
                    </h3>

                    <p>
                      <strong>Muscle group:</strong>
                      <%= workoutExercise.exercise.muscleGroup %>
                    </p>

                    <p>
                      <strong>Equipment:</strong>
                      <%= workoutExercise.exercise.equipment %>
                    </p>

                    <p>
                      <strong>Instructions:</strong>
                      <%= workoutExercise.exercise.instructions %>
                    </p>
                  </div>
                </div>
              <% } %>

              <div class="sets-section">
                <h4>Sets</h4>

                <% if (workoutExercise.sets.length === 0) { %>
                  <p class="secondary-text">No sets found.</p>
                <% } else { %>
                  <% for (let set of workoutExercise.sets) { %>
                    <% if (isOwner) { %>
                      <form
                        class="set-row"
                        action="/routines/<%= routine._id %>/exercises/<%= workoutExercise._id %>/sets/<%= set._id %>?_method=PUT"
                        method="POST"
                      >
                        <div class="set-input">
                          <label for="reps-<%= set._id %>">Reps</label>

                          <input
                            type="number"
                            id="reps-<%= set._id %>"
                            name="reps"
                            min="1"
                            value="<%= set.reps %>"
                            required
                          />
                        </div>

                        <div class="set-input">
                          <label for="weight-<%= set._id %>">
                            Weight
                          </label>

                          <input
                            type="number"
                            id="weight-<%= set._id %>"
                            name="weight"
                            min="0"
                            value="<%= set.weight %>"
                            required
                          />
                        </div>

                        <div class="completed-input">
                          <input
                            type="checkbox"
                            id="completed-<%= set._id %>"
                            name="completed"
                            <% if (set.completed) { %>
                              checked
                            <% } %>
                          />

                          <label for="completed-<%= set._id %>">
                            Completed
                          </label>
                        </div>
                      </form>
                    <% } else { %>
                      <div class="set-display">
                        <span>Reps: <%= set.reps %></span>

                        <span>Weight: <%= set.weight %> kg</span>

                        <% if (set.completed) { %>
                          <span>Completed</span>
                        <% } else { %>
                          <span>Not completed</span>
                        <% } %>
                      </div>
                    <% } %>
                  <% } %>
                <% } %>
              </div>

              <% if (isOwner) { %>
                <div class="exercise-buttons">
                  <a
                    href="/routines/<%= routine._id %>/exercises/<%= workoutExercise._id %>/edit"
                    class="secondary-button"
                  >
                    Edit Exercise
                  </a>

                  <form
                    action="/routines/<%= routine._id %>/exercises/<%= workoutExercise._id %>?_method=DELETE"
                    method="POST"
                  >
                    <button type="submit" class="delete-button">
                      Delete Exercise
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% } %>
        </div>
      <% } %>

      <div class="bottom-actions">
        <a href="/routines" class="secondary-button">
          Back to My Routines
        </a>

        <% if (isOwner) { %>
          <form
            action="/routines/<%= routine._id %>?_method=DELETE"
            method="POST"
          >
            <button type="submit" class="delete-button">
              Delete Routine
            </button>
          </form>
        <% } %>
      </div>
    </main>
  </body>
</html>
