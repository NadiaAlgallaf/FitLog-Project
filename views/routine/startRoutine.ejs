<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Create Routine</title>
  </head>

  <body>
    <%- include('../partials/navbar.ejs') %>

    <main class="form-page">
      <div class="form-card">
        <p class="small-title">Workout</p>

        <h1>Create New Routine</h1>

        <form action="/routines" method="POST">
          <label for="workoutName">Routine Name</label>

          <input type="text" id="workoutName" name="workoutName" required />

          <label for="description">Description</label>

          <textarea id="description" name="description" rows="4"></textarea>

          <div class="checkbox-row">
            <input type="checkbox" id="isPublic" name="isPublic" />

            <label for="isPublic"> Make this routine public </label>
          </div>

          <button type="submit" class="primary-button">Create Routine</button>
        </form>

        <a href="/routines" class="secondary-button cancel-button"> Cancel </a>
      </div>
    </main>
  </body>
</html>
