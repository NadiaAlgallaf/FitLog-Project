<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Exercise</title>
  </head>

  <body>
    <%- include('../partials/navbar.ejs') %>
    <h1>Add Exercise to <%= workout.workoutName %></h1>

    <form
      action="/routines/<%= workout._id %>/exercises"
      method="POST"
    >
      <label for="exercise">Select exercise:</label>

      <select name="exercise" id="exercise" required>
        <option value="">Choose an exercise</option>

        <% for (let exercise of exercises) { %>
          <option value="<%= exercise._id %>">
            <%= exercise.exerciseName %> -
            <%= exercise.muscleGroup %>
          </option>
        <% } %>
      </select>

      <br /><br />

      <label for="numberOfSets">Number of sets:</label>
      <input
        type="number"
        id="numberOfSets"
        name="numberOfSets"
        min="1"
        value="3"
        required
      />

      <br /><br />

      <label for="reps">Reps:</label>
      <input
        type="number"
        id="reps"
        name="reps"
        min="1"
        value="10"
        required
      />

      <br /><br />

      <label for="weight">Weight:</label>
      <input
        type="number"
        id="weight"
        name="weight"
        min="0"
        value="0"
        required
      />

      <br /><br />

      <button type="submit">Add Exercise</button>
    </form>

    <hr />

    <h2>Exercises Added to This Routine</h2>

    <% if (workoutExercises.length === 0) { %>
      <p>No exercises added yet.</p>
    <% } else { %>
      <% for (let workoutExercise of workoutExercises) { %>
        <div>
          <h3><%= workoutExercise.exercise.exerciseName %></h3>

          <p>
            Muscle group:
            <%= workoutExercise.exercise.muscleGroup %>
          </p>

          <p>
            Number of sets:
            <%= workoutExercise.sets.length %>
          </p>

          <% for (let set of workoutExercise.sets) { %>
            <p>
              <%= set.reps %> reps -
              <%= set.weight %> kg
            </p>
          <% } %>
        </div>

        <hr />
      <% } %>
    <% } %>

    <a href="/routines/<%= workout._id %>">
      Finish Routine
    </a>
  </body>
</html>
