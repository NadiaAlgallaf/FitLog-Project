<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Exercise</title>

    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <%- include('../partials/navbar.ejs') %>

    <main class="page-container">
      <div class="content-container">
        <div class="page-heading">
          <p class="small-title">Update Exercise</p>

          <h1><%= workoutExercise.exercise.exerciseName %></h1>

          <p class="secondary-text">
            Change the number of sets, reps, or weight.
          </p>
        </div>

        <form
          class="form-card"
          action="/routines/<%= routineId %>/exercises/<%= workoutExercise._id %>?_method=PUT"
          method="POST"
        >
          <div class="form-group">
            <label for="numberOfSets">Number of sets</label>

            <input
              type="number"
              id="numberOfSets"
              name="numberOfSets"
              min="1"
              value="<%= workoutExercise.sets.length %>"
              required
            />
          </div>

          <div class="form-group">
            <label for="reps">Reps for new sets</label>

            <input
              type="number"
              id="reps"
              name="reps"
              min="1"
              value="<%= workoutExercise.sets.length > 0 ? workoutExercise.sets[0].reps : 10 %>"
              required
            />
          </div>

          <div class="form-group">
            <label for="weight">Weight for new sets</label>

            <input
              type="number"
              id="weight"
              name="weight"
              min="0"
              value="<%= workoutExercise.sets.length > 0 ? workoutExercise.sets[0].weight : 0 %>"
              required
            />
          </div>

          <div class="form-actions">
            <button type="submit" class="primary-button">Save Changes</button>

            <a
              href="/routines/add-exercises/<%= routineId %>"
              class="secondary-button"
            >
              Cancel
            </a>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
