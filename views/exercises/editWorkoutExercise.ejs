<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Exercise</title>
  </head>

  <body>
    <%- include('../partials/navbar.ejs') %>
    <h1>Edit <%= workoutExercise.exercise.exerciseName %></h1>

    <form
      action="/routines/<%= routineId %>/exercises/<%= workoutExercise._id %>?_method=PUT"
      method="POST"
    >
      <label for="numberOfSets">Number of sets:</label>

      <input
        type="number"
        id="numberOfSets"
        name="numberOfSets"
        min="1"
        value="<%= workoutExercise.sets.length %>"
        required
      />

      <br /><br />

      <label for="reps">Reps for new sets:</label>

      <input
        type="number"
        id="reps"
        name="reps"
        min="1"
        value="<%= workoutExercise.sets.length > 0 ? workoutExercise.sets[0].reps : 10 %>"
        required
      />

      <br /><br />

      <label for="weight">Weight for new sets:</label>

      <input
        type="number"
        id="weight"
        name="weight"
        min="0"
        value="<%= workoutExercise.sets.length > 0 ? workoutExercise.sets[0].weight : 0 %>"
        required
      />

      <br /><br />

      <button type="submit">Save Changes</button>
    </form>

    <br />

    <a href="/routines/add-exercises/<%= routineId %>"> Cancel </a>
  </body>
</html>
